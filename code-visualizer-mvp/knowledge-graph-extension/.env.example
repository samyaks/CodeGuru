# UpdateAI Extension - Environment Configuration
# Copy this file to src/api/config.js and fill in your values

# =============================================================================
# SUPABASE CONFIGURATION (Required)
# =============================================================================
# Get these values from: https://supabase.com/dashboard/project/_/settings/api

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# =============================================================================
# API CONFIGURATION (Optional - has defaults)
# =============================================================================

# API Base URL
API_BASE_URL=https://api.updateai.app

# Request timeout in milliseconds
API_TIMEOUT=30000

# Number of retry attempts for failed requests
API_RETRY_ATTEMPTS=3

# Delay between retries in milliseconds
API_RETRY_DELAY=1000

# =============================================================================
# SYNC CONFIGURATION (Optional - has defaults)
# =============================================================================

# Maximum number of sync retry attempts before giving up
SYNC_MAX_RETRY_ATTEMPTS=10

# Base delay for exponential backoff (in milliseconds)
SYNC_BASE_BACKOFF_DELAY=1000

# Maximum backoff delay (5 minutes default)
SYNC_MAX_BACKOFF_DELAY=300000

# Number of items to sync in each batch
SYNC_BATCH_SIZE=10

# How often to check for pending syncs (5 minutes default)
SYNC_PERIODIC_INTERVAL=300000

# How often to pull updates from server (10 minutes default)
SYNC_PULL_INTERVAL=600000

# =============================================================================
# STORAGE CONFIGURATION (Optional - has defaults)
# =============================================================================

# Storage quota threshold (0.9 = 90%)
STORAGE_QUOTA_THRESHOLD=0.9

# Maximum number of conflicts to store
STORAGE_MAX_CONFLICTS=50

# Maximum number of failed sync operations to track
STORAGE_MAX_FAILURES=100

# =============================================================================
# FEATURE FLAGS (Optional - has defaults)
# =============================================================================

# Enable offline mode
ENABLE_OFFLINE_MODE=true

# Enable real-time synchronization
ENABLE_REAL_TIME=true

# Enable collaboration features
ENABLE_COLLABORATION=true

# Development mode (shows more console logs)
IS_DEV=false
