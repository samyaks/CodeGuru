{
  "name": "@updateai/backend",
  "version": "1.0.0",
  "description": "UpdateAI backend infrastructure and API client",
  "main": "src/client/index.ts",
  "types": "src/client/index.ts",
  "scripts": {
    "dev": "supabase start",
    "stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:push": "supabase db push",
    "db:pull": "supabase db pull",
    "migration:new": "supabase migration new",
    "types:generate": "supabase gen types typescript --local > src/types/database.ts",
    "types:generate:remote": "supabase gen types typescript > src/types/database.ts",
    "build": "tsc",
    "test": "jest",
    "lint": "eslint src --ext .ts,.tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx,json}\"",
    "setup": "node scripts/setup.js"
  },
  "keywords": [
    "updateai",
    "supabase",
    "api-client",
    "collaboration",
    "prompts"
  ],
  "author": "UpdateAI Team",
  "license": "MIT",
  "dependencies": {
    "@supabase/supabase-js": "^2.39.3"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "@typescript-eslint/eslint-plugin": "^6.19.1",
    "@typescript-eslint/parser": "^6.19.1",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.4",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/updateai/backend.git"
  }
}
