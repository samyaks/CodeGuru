# Required
ANTHROPIC_API_KEY=sk-ant-...

# Required for deploy — Railway API token (get from railway.com/account/tokens)
RAILWAY_API_TOKEN=...

# Optional — increases GitHub API rate limit from 60/hr to 5000/hr
GITHUB_TOKEN=ghp_...

# Optional — enables auth (omit to run without authentication)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_REDIRECT_URL=http://localhost:3000/auth/callback

# Optional
PORT=3001
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
