# Server
PORT=3001
NODE_ENV=development

# URLs — change these when deploying to production
API_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000

# Anthropic Claude — required for analysis + context generation
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Claude model — optional, which model ID to use (defaults to claude-sonnet-4-20250514 if unset)
CLAUDE_MODEL=claude-sonnet-4-20250514

# GitHub — optional, increases API rate limit from 60 to 5000 req/hr
GITHUB_TOKEN=ghp_your-token-here

# GitHub webhook — HMAC secret for POST /api/github/webhook (push → per-project commit review)
# Required in production. Generate a long random string and paste the same value in the repo webhook settings.
GITHUB_WEBHOOK_SECRET=

# Optional caps for webhook-driven commit reviews (diff size)
# MAX_COMMIT_REVIEW_FILES=40
# MAX_COMMIT_REVIEW_PATCH_CHARS=10000

# Railway — required for customer app deployment
RAILWAY_API_TOKEN=your-railway-api-token

# Supabase Auth — optional, enables login/persistence/deploy
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ-your-anon-key
SUPABASE_REDIRECT_URL=http://localhost:3000/auth/callback

# Supabase Management API — optional, enables automatic URL sync to Supabase Auth (site_url / redirect_urls)
SUPABASE_MANAGEMENT_KEY=sbp_your-personal-access-token

# CORS — comma-separated origins allowed to call the API (defaults to API_URL + FRONTEND_URL if unset)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ─── Database ────────────────────────────────────────────────────
# Supabase Postgres — session pooler URL for the running server (pooled)
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
# Direct connection for running migrations (DDL, advisory locks). Optional at runtime.
DATABASE_URL_DIRECT=postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres
