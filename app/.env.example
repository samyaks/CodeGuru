# Server
PORT=3001
NODE_ENV=development

# Anthropic Claude — required for analysis + context generation
ANTHROPIC_API_KEY=sk-ant-your-key-here

# GitHub — optional, increases API rate limit from 60 to 5000 req/hr
GITHUB_TOKEN=ghp_your-token-here

# Railway — required for customer app deployment
RAILWAY_API_TOKEN=your-railway-api-token

# Supabase Auth — optional, enables login/persistence/deploy
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ-your-anon-key
SUPABASE_REDIRECT_URL=http://localhost:3000/auth/callback

# CORS — comma-separated origins allowed to call the API
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
